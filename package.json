{
  "name": "sgc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Salience-Gated Cognition — a tiered-memory conversational architecture prototype.",
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8",
    "dotenv": "^16.4",
    "express": "^4.21",
    "lucide-react": "^1.16.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3",
    "@types/cors": "^2.8",
    "@types/express": "^4.17",
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@typescript-eslint/eslint-plugin": "^8.20",
    "@typescript-eslint/parser": "^8.20",
    "@vitejs/plugin-react": "^4.3",
    "concurrently": "^9.1",
    "eslint": "^9.18",
    "eslint-plugin-react-hooks": "^5.1",
    "jsdom": "^25",
    "react": "^19.2",
    "react-dom": "^19.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19",
    "typescript": "^5.6",
    "vite": "^6.0",
    "vitest": "^2.1"
  }
}
