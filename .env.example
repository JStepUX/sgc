# SGC server (the turn proxy) — src/server/index.ts
PORT=3000
NODE_ENV=development

# Origin allowed by CORS — the Vite dev client.
CORS_ORIGIN=http://localhost:5555

# Anthropic API. The server holds this key; it is NEVER shipped to the
# browser. The React client only ever calls /api/turn on this server.
ANTHROPIC_API_KEY=sk-ant-...

# Reasoning model for Sal, the ephemeral reasoning instance. Defaults to
# Claude Opus 4.7. Override with e.g. claude-sonnet-4-6 to trade depth for
# speed/cost.
ANTHROPIC_MODEL=claude-opus-4-7

# Max output tokens per turn (Sal's natural-language reply + JSON metadata).
# Keep this generous: if a long reply is truncated before the trailing JSON
# block, parseTurnResponse finds no metadata and confidence scores silently
# stop updating.
ANTHROPIC_MAX_TOKENS=16384

# ---------------------------------------------------------------------------
# LOCAL MODEL PROVIDER (OpenAI-compatible: KoboldCPP, Ollama, …)
#
# Sal's single reasoning call can be pointed at a local OpenAI-compatible model
# server instead of Anthropic, selectable at runtime from the header chip. The
# client only ever sends a provider TOKEN ('anthropic'|'openai'); the server
# holds the key/URL below. A local model is just a different (still ephemeral)
# Sal — the memory tiers (cosine grep + URL pre-fetch) stay deterministic.
# Anthropic-only deploy: leave OPENAI_BASE_URL unset → picker shows LOCAL
# disabled. Web tools (web_search/web_fetch) are Anthropic-only and dark on the
# local path. Context length is configured in the local server itself, not here.
# ---------------------------------------------------------------------------

# Provider used at boot when the client doesn't specify: "anthropic" | "openai".
# Ignored if it names a provider that isn't configured (then: anthropic if its
# key is set, else openai if its base URL is set). LOCAL is opt-in (below), so
# the default ships as anthropic — the common, zero-local-infra setup. Flip this
# to "openai" only once OPENAI_BASE_URL is set and you want LOCAL as the default.
LLM_PROVIDER=anthropic

# Base URL of the local OpenAI-compatible server. LEFT UNSET BY DEFAULT so a
# plain "copy this file + add an Anthropic key" setup never tries to reach a
# local server that isn't running. Uncomment to enable the LOCAL provider:
# KoboldCPP defaults to :5001/v1; Ollama is :11434/v1 — same code path, only the
# URL differs.
# OPENAI_BASE_URL=http://localhost:5001/v1

# API key for the local server. KoboldCPP ignores it; leave blank.
OPENAI_API_KEY=

# Model label only — the local server serves whatever model is loaded. Shown in
# the provider picker.
LLM_MODEL=koboldcpp

# Max output tokens per turn on the local path. Keep modest — local context
# windows are small (and configured in the local server).
LLM_MAX_TOKENS=512
