# SGC server (the turn proxy) — src/server/index.ts
PORT=3000
NODE_ENV=development

# Origin allowed by CORS — the Vite dev client.
CORS_ORIGIN=http://localhost:5555

# Anthropic API. The server holds this key; it is NEVER shipped to the
# browser. The React client only ever calls /api/turn on this server.
ANTHROPIC_API_KEY=sk-ant-...

# Reasoning model for Sal, the ephemeral reasoning instance. Defaults to
# Claude Opus 4.7. Override with e.g. claude-sonnet-4-6 to trade depth for
# speed/cost.
ANTHROPIC_MODEL=claude-opus-4-7

# Max output tokens per turn (Sal's natural-language reply + JSON metadata).
# Keep this generous: if a long reply is truncated before the trailing JSON
# block, parseTurnResponse finds no metadata and confidence scores silently
# stop updating.
ANTHROPIC_MAX_TOKENS=16384
