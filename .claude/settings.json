{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(bash scripts/agent/*)",
      "Bash(node .claude/skills/pre-commit-qa/write-marker.mjs)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-gate.mjs",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ]
  }
}
